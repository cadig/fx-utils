# Copy this file to credentials.env (same directory) and fill in real values.
# credentials.env is gitignored and must never be committed.

# OANDA Personal Access Token (generate at https://www.oanda.com/account/tpa/personal_token)
OANDA_TOKEN=your-personal-access-token-here

# "practice" (fxpractice) or "live" (fxtrade)
OANDA_ENVIRONMENT=practice
